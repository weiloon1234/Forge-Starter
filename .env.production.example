# =============================================================================
# Production Environment
# =============================================================================
# Copy to .env.production on the machine that runs `make deploy`.
#
# scripts/build.sh reads this file locally only:
# - DEPLOY_* selects where artifact zip + VERSION are uploaded.
# - VITE_* is public and baked into frontend bundles during Docker build.
#
# This file is never uploaded by deploy. Server runtime secrets must be set once
# on the server at /opt/{app}-{environment}/.env.

# --- Deploy Artifact Bucket ---
DEPLOY_BUCKET=
DEPLOY_REGION=auto
DEPLOY_ENDPOINT=

# --- Frontend Build-Time Variables (public) ---
VITE_APP_NAME=Forge Starter
VITE_APP_ENV=production
VITE_APP_URL=https://example.com
VITE_API_URL=https://example.com
VITE_WS_URL=wss://example.com/ws
VITE_STORAGE_URL=https://asset.example.com
