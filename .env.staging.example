# =============================================================================
# Staging Environment
# =============================================================================
# Copy to .env.staging and fill in real values.
# VITE_* vars are injected into frontend during Docker build.
# Server vars are deployed to the server via S3/R2 bucket.

# --- Server Config ---
APP_ENV=staging
APP_KEY=base64:generate-me

DATABASE_URL=postgres://forge:secret@127.0.0.1:5432/forge_starter_staging
REDIS_URL=redis://127.0.0.1:6379

# --- Frontend Build-Time Variables ---
VITE_API_URL=https://staging-api.example.com
VITE_APP_NAME=Forge Starter (Staging)
