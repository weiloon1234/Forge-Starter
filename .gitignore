# Rust (Cargo.lock IS committed — this is a binary crate)
/target

# Environment
.env
.env.staging
.env.production

# Logs
logs/

# Storage (runtime uploads)
storage/

# Frontend build output (regenerated by vite build)
public/admin/*
!public/admin/.gitkeep
public/user/*
!public/user/.gitkeep

# Node
node_modules/

# TypeScript build output (generated by tsc -b)
frontend/**/*.js
frontend/**/*.js.map
frontend/**/*.d.ts
frontend/**/tsconfig.tsbuildinfo
frontend/shared/dist/

# ts-rs stale output (use make types)
/bindings/

# Build config (per-developer)
scripts/.build.conf

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Claude Code (keep skills, ignore the rest)
.claude/*
!.claude/skills/
