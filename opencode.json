{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "biome": {
      "command": ["npx", "biome", "check", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx"
      ]
    },
    "rustfmt": {
      "command": ["rustfmt", "--edition", "2021", "$FILE"],
      "extensions": [".rs"]
    }
  }
}
