[Unit]
Description=Forge Starter — Task Scheduler
After=network.target postgresql.service redis.service
Wants=postgresql.service redis.service

[Service]
Type=simple
User=forge
Group=forge
WorkingDirectory=/opt/forge-starter
Environment=PROCESS=scheduler
EnvironmentFile=/opt/forge-starter/.env
ExecStart=/opt/forge-starter/bin/forge-starter
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=forge-scheduler

[Install]
WantedBy=multi-user.target
